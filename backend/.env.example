APP_NAME=web-app-document
PORT=3010
BASE_URL_PREFIX=/api

API_BASE_URL=

CLIENT_KEY=
CLIENT_SECRET=

LOG_FORMAT=dev
LOG_DIR=../../data/logs

ORIGIN=http://localhost:3000
REDIRECT_URL=http://localhost:3000

MUNICIPALITY_ID=2281
NAMESPACE=

# Auth — set AUTH_TYPE=token for testing without IdP, AUTH_TYPE=saml for production
AUTH_TYPE=token
ACCESS_TOKEN=test-token-change-me
SECRET_KEY=session-secret-change-me
SESSION_MEMORY=true
CREDENTIALS=true

# SAML (only used when AUTH_TYPE=saml)
SAML_CALLBACK_URL=
SAML_LOGOUT_CALLBACK_URL=
SAML_FAILURE_REDIRECT=
SAML_ENTRY_SSO=
SAML_ISSUER=web-app-document
SAML_IDP_PUBLIC_CERT=
SAML_PRIVATE_KEY=
SAML_PUBLIC_KEY=
AUTHORIZED_GROUPS=
ADMIN_GROUP=
USER_GROUP=

# Eneo AI chat — proxied through WSO2 gateway (/eneo-sundsvall/1.2/).
# OAuth2 Bearer (from CLIENT_KEY/SECRET) handles WSO2's subscription check;
# the key below is sent as `api-key: <key>` for Eneo's own auth — same
# pattern web-app-felanmalan uses against the same gateway.
ENEO_API_KEY=
ENEO_ASSISTANT_ID=
