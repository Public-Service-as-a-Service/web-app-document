{
  "name": "web-app-document-backend",
  "version": "1.0.0",
  "description": "Backend for document web app",
  "scripts": {
    "dev": "cross-env NODE_ENV=development nodemon",
    "build": "tsc && tsc-alias",
    "start": "node dist/server.js",
    "start:prod": "cross-env NODE_ENV=production node dist/server.js",
    "lint": "eslint src/",
    "type-check": "tsc --pretty --noEmit"
  },
  "dependencies": {
    "@node-saml/passport-saml": "5.1.0",
    "axios": "1.15.0",
    "compression": "1.8.1",
    "cookie-parser": "1.4.7",
    "cors": "2.8.6",
    "dotenv": "16.6.1",
    "express": "4.22.1",
    "express-rate-limit": "7.5.1",
    "express-session": "1.19.0",
    "form-data": "4.0.5",
    "helmet": "8.1.0",
    "hpp": "0.2.3",
    "memorystore": "1.6.7",
    "morgan": "1.10.1",
    "multer": "2.1.1",
    "passport": "0.7.0",
    "qs": "6.15.1",
    "reflect-metadata": "0.2.2",
    "class-transformer": "0.5.1",
    "class-validator": "0.14.1",
    "routing-controllers": "0.10.4",
    "session-file-store": "1.5.0",
    "uuid": "11.1.0",
    "winston": "3.19.0",
    "winston-daily-rotate-file": "5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/compression": "1.8.1",
    "@types/cookie-parser": "1.4.10",
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/express-session": "1.18.2",
    "@types/hpp": "0.2.7",
    "@types/morgan": "1.9.10",
    "@types/multer": "2.1.0",
    "@types/node": "22.19.17",
    "@types/passport": "1.0.17",
    "@types/qs": "6.15.0",
    "@types/uuid": "10.0.0",
    "cross-env": "7.0.3",
    "eslint": "10.2.0",
    "nodemon": "3.1.14",
    "ts-node": "10.9.2",
    "tsc-alias": "1.8.16",
    "tsconfig-paths": "4.2.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.58.1"
  }
}
