            type: boolean
            default: false
          example: false
        - name: accessType
          in: query
          description: How this access should be classified in usage statistics.
          required: false
          schema:
            type: string
            default: DOWNLOAD
            enum:
              - DOWNLOAD
              - VIEW
          example: DOWNLOAD
        - name: countStats
          in: query
          description: Whether this access should be counted in usage statistics. Set
            to false for admin previews and test downloads.
          required: false
          schema:
            type: boolean
            default: true
          example: true
        - name: X-Sent-By
          in: header
          description: "Identifier of the caller, recorded in usage statistics."
          required: false
          schema:
            type: string
      responses:
        "200":
          description: Successful operation
        "404":
          description: Not found
          content:
            application/problem+json:
              schema:
                $ref: "#/components/schemas/Problem"
        "400":
          description: Bad request
          content:
            application/problem+json:
              schema:
                oneOf:
                  - $ref: "#/components/schemas/Problem"
                  - $ref: "#/components/schemas/ConstraintViolationProblem"
        "500":
          description: Internal Server error
          content:
            application/problem+json:
              schema:
                $ref: "#/components/schemas/Problem"
    delete:
      tags:
        - Documents
      summary: Delete document file.
      operationId: deleteFile
      parameters:
        - name: municipalityId
          in: path
          description: Municipality ID
          required: true
          schema:
            type: string
          example: 2281
        - name: registrationNumber
          in: path
          description: Document registration number
          required: true
          schema:
            type: string
          example: 2023-2281-1337
        - name: documentDataId
          in: path
          description: Document data ID
          required: true
          schema:
            type: string
          example: 082ba08f-03c7-409f-b8a6-940a1397ba38
      responses:
        "204":
          description: Successful operation
        "404":
          description: Not found
          content:
            application/problem+json:
              schema:
                $ref: "#/components/schemas/Problem"
        "400":
          description: Bad request
          content:
            application/problem+json:
              schema:
                oneOf:
                  - $ref: "#/components/schemas/Problem"
                  - $ref: "#/components/schemas/ConstraintViolationProblem"
        "500":
          description: Internal Server error
          content:
            application/problem+json:
              schema:
                $ref: "#/components/schemas/Problem"
  /api-docs:
    get:
      tags:
        - API
      summary: OpenAPI
      operationId: getApiDocs
      responses:
        "200":
          description: OK
          content:
            application/yaml:
              schema:
                type: string
      x-auth-type: None
      x-throttling-tier: Unlimited
      x-wso2-mutual-ssl: Optional
components:
  schemas:
    Problem:
      type: object
      properties:
        title:
          type: string
        detail:
          type: string
        instance:
          type: string
          format: uri
        type:
          type: string
          format: uri
        status:
          type: integer
          format: int32
    DocumentResponsibilitiesUpdateRequest:
      type: object
      description: Document responsibilities update request model.
      properties:
        updatedBy:
          type: string
          description: PersonId of the actor that performed this change.
          examples:
            - 6c3e4f5a-7b8d-4e9c-a1f2-d3e4b5c6a7f8
          minLength: 1
        responsibilities:
          type: array
          items:
            $ref: "#/components/schemas/DocumentResponsibility"
            description: List of document responsibilities.
      required:
        - updatedBy
        - responsibilities
    DocumentResponsibility:
      type: object
      description: Document responsibility model.
      properties:
        personId:
          type: string
          description: Person ID of the responsible party.
          examples:
            - 6b8d4a1c-34e2-4f73-a5f1-b7c2e9a0d8c4
          minLength: 1
      required:
        - personId
    ConstraintViolationProblem:
      type: object
      properties:
        type:
          type: string
          format: uri
        status:
          type: integer
          format: int32
        violations:
          type: array
          items:
            $ref: "#/components/schemas/Violation"
        title:
          type: string
        causeAsProblem:
          $ref: "#/components/schemas/ThrowableProblem"
        detail:
          type: string
        instance:
          type: string
          format: uri
    ThrowableProblem:
      type: object
      properties:
        type:
          type: string
          format: uri
        title:
          type: string
        status:
          type: integer
          format: int32
        detail:
          type: string
        instance:
          type: string
          format: uri
        causeAsProblem: {}
    Violation:
      type: object
      properties:
        field:
          type: string
        message:
          type: string
    DocumentDataCreateRequest:
      type: object
      description: DocumentDataCreateRequest model.
      properties:
        createdBy:
          type: string
          description: PersonId of the actor that created this revision.
          examples:
            - 6c3e4f5a-7b8d-4e9c-a1f2-d3e4b5c6a7f8
          minLength: 1
        filesToDelete:
          type: array
          items:
            type: string
            description: "Document data IDs (from the current revision) to drop in\
              \ the new revision. Combined with any uploaded files to produce a\
              \ single revision bump. Unknown IDs → 404."
            examples:
              - 082ba08f-03c7-409f-b8a6-940a1397ba38
      required:
        - createdBy
    Confidentiality:
      type: object
      description: Confidentiality model.
      properties:
        confidential:
          type: boolean
          description: |
            A flag that can be set to alert administrative users handling the information that there are some special privacy policies to follow for the person in question.
            If there are special privacy policies to follow for this record, this flag should be set to 'true', otherwise 'false'.
          examples:
            - "true"
        legalCitation:
          type: string
          description: Legal citation
          examples:
            - 25 kap. 1 § OSL
    DocumentCreateRequest:
      type: object
      description: DocumentCreateRequest model.
      properties:
        createdBy:
          type: string
          description: PersonId of the actor that created this revision (all modifications
            will create new revisions).
          examples:
            - 6c3e4f5a-7b8d-4e9c-a1f2-d3e4b5c6a7f8
          minLength: 1
        confidentiality:
          $ref: "#/components/schemas/Confidentiality"
          description: Confidentiality
        archive:
          type: boolean
          description: Tells if the document is eligible for archiving
          examples:
            - "false"
        title:
          type: string
          description: Document title
          examples:
            - Employment certificate for John Doe. Maximum 255 characters.
          maxLength: 255
          minLength: 0
        description:
          type: string
          description: Document description
          examples:
            - A brief description of this object. Maximum 8192 characters.
          maxLength: 8192
          minLength: 0
        metadataList:
          type: array
          description: List of DocumentMetadata objects.
          items:
            $ref: "#/components/schemas/DocumentMetadata"
        responsibilities:
          type: array
          description: Document responsibilities.
          items:
            $ref: "#/components/schemas/DocumentResponsibility"
        type:
          type: string
          description: The type of document (validated against a defined list of document
            types).
          examples:
            - EMPLOYMENT_CERTIFICATE
          minLength: 1
        validFrom:
          type: string
          format: date
          description: Start of validity period (inclusive). ISO date (yyyy-MM-dd).
          examples:
            - 2026-04-15
        validTo:
          type: string
          format: date
          description: End of validity period (inclusive). ISO date (yyyy-MM-dd).
          examples:
            - 2027-04-15
      required:
        - createdBy
        - description
        - title
        - type
    DocumentMetadata:
      type: object
      description: DocumentMetadata model
      properties:
        key:
          type: string
          description: Metadata key
          examples:
            - Some key
          minLength: 1
        value:
          type: string
          description: Metadata value
          examples:
            - Some value
          minLength: 1
      required:
        - key
        - value
    Direction:
      type: string
      enum:
        - ASC
        - DESC
    DocumentParameters:
      type: object
      properties:
        page:
          type: integer
          format: int32
          default: 1
          description: Page number
          examples:
            - "1"
          minimum: 1
        limit:
          type: integer
          format: int32
          description: Result size per page. Maximum allowed value is dynamically
            configured
          examples:
            - "15"
          minimum: 1
        sortBy:
          type: array
          items:
            type: string
            description: The properties to sort on
            examples:
              - propertyName
        sortDirection:
          $ref: "#/components/schemas/Direction"
          description: The sort order direction
          examples:
            - ASC
        municipalityId:
          type: string
          description: Municipality identifier
          examples:
            - "1234"
          readOnly: true
        createdBy:
          type: string
          description: Filter by personId of the actor that created the document.
          examples:
            - 6c3e4f5a-7b8d-4e9c-a1f2-d3e4b5c6a7f8
        includeConfidential:
          type: boolean
          default: false
          description: Should the search include confidential documents?
          examples:
            - "true"
        onlyLatestRevision:
          type: boolean
          default: false
          description: Should the search include only the latest revision of the documents?
          examples:
            - "true"
        documentTypes:
          type: array
          description: List of document types
          items:
            type: string
        metaData:
          type: array
          items:
            $ref: "#/components/schemas/MetaData"
            description: List of metadata
        responsibilities:
          type: array
          items:
            $ref: "#/components/schemas/DocumentResponsibility"
            description: List of document responsibilities. Documents match if at
              least one responsibility matches.
        validOn:
          type: string
          format: date
          description: Only include documents whose validity window covers this date.
            A null validFrom is treated as valid from the beginning of time; a null
            validTo is treated as valid forever. ISO date (yyyy-MM-dd).
          examples:
            - 2026-04-15
        statuses:
          type: array
          items:
            type: string
            description: "Lifecycle statuses to include. Defaults to published statuses\
              \ (SCHEDULED, ACTIVE, EXPIRED) - DRAFT and REVOKED are excluded. When\
              \ set explicitly, the list is used as-is."
            enum:
              - DRAFT
              - SCHEDULED
              - ACTIVE
              - EXPIRED
              - REVOKED
    MetaData:
      type: object
      properties:
        key:
          type: string
          description: Metadata key
          examples:
            - Some key
        matchesAny:
          type: array
          items:
            type: string
            description: List of metadata values
        matchesAll:
          type: array
          items:
            type: string
            description: List of metadata values
    Document:
      type: object
      description: Document model.
      properties:
        id:
          type: string
          description: ID of the document.
          examples:
            - 0d64c132-3aea-11ec-8d3d-0242ac130003
        municipalityId:
          type: string
          description: Municipality ID
          examples:
            - "2281"
        registrationNumber:
          type: string
          description: "Registration number on the format [YYYY-nnnn-nnnn]."
          examples:
            - 2023-2281-1337
        revision:
          type: integer
          format: int32
          description: Document revision.
          examples:
            - "2"
        confidentiality:
          $ref: "#/components/schemas/Confidentiality"
          description: Confidentiality
        title:
          type: string
          description: Document title
          examples:
            - Employment certificate for John Doe.
        description:
          type: string
          description: Document description
          examples:
            - A brief description of this object.
        created:
          type: string
          format: date-time
          description: Timestamp when document revision was created.
          examples:
            - 2023-08-31T01:30:00.000+02:00
        createdBy:
          type: string
          description: PersonId of the actor that created this revision.
          examples:
            - 6c3e4f5a-7b8d-4e9c-a1f2-d3e4b5c6a7f8
        updatedBy:
          type: string
          description: PersonId of the actor that last updated this document.
          examples:
            - 6c3e4f5a-7b8d-4e9c-a1f2-d3e4b5c6a7f8
        archive:
          type: boolean
          description: Tells if the document is eligible for archiving
          examples:
            - "false"
        metadataList:
          type: array
          description: List of DocumentMetadata objects.
          items:
            $ref: "#/components/schemas/DocumentMetadata"
        documentData:
          type: array
          description: Document data
          items:
            $ref: "#/components/schemas/DocumentData"
        responsibilities:
          type: array
          description: Document responsibilities.
          items:
            $ref: "#/components/schemas/DocumentResponsibility"
        type:
          type: string
          description: Document type
          examples:
            - Type for the document.
        validFrom:
          type: string
          format: date
          description: Start of validity period (inclusive). ISO date (yyyy-MM-dd).
          examples:
            - 2026-04-15
        validTo:
          type: string
          format: date
          description: End of validity period (inclusive). ISO date (yyyy-MM-dd).
          examples:
            - 2027-04-15
        status:
          type: string
          description: Lifecycle status of this revision.
          enum:
            - DRAFT
            - SCHEDULED
            - ACTIVE
            - EXPIRED
            - REVOKED
          examples:
            - ACTIVE
      readOnly: true
    DocumentData:
      type: object
      description: DocumentData model.
      properties:
        id:
          type: string
          description: ID of the document data.
          examples:
            - 082ba08f-03c7-409f-b8a6-940a1397ba38
        fileName:
          type: string
          description: File name.
          examples:
            - my-file.pdf
        mimeType:
          type: string
          description: The mime type of the file.
          examples:
            - application/pdf
        fileSizeInBytes:
          type: integer
          format: int64
          description: File size in bytes
          examples:
            - "5068"
      readOnly: true
    PagedDocumentResponse:
      type: object
      description: Paged document response model
      properties:
        documents:
          type: array
          items:
            $ref: "#/components/schemas/Document"
        _meta:
          $ref: "#/components/schemas/PagingMetaData"
      readOnly: true
    PagedDocumentMatchResponse:
      type: object
      description: "Paged document match response — documents that matched a fulltext\
        \ search, stripped to the matching files."
      properties:
        documents:
          type: array
          items:
            $ref: "#/components/schemas/DocumentMatch"
        _meta:
          $ref: "#/components/schemas/PagingMetaData"
      readOnly: true
    DocumentMatch:
      type: object
      description: Document match — a document that contains one or more files matching
        a fulltext search.
      properties:
        id:
          type: string
          description: "ID of the matching document (revision-specific, copy-on-write\
            \ creates a new ID per revision)."
          examples:
            - 082ba08f-03c7-409f-b8a6-940a1397ba38
        registrationNumber:
          type: string
          description: Registration number of the matching document.
          examples:
            - 2023-2281-1337
        revision:
          type: integer
          format: int32
          description: Revision that the matched files belong to.
          examples:
            - "3"
        files:
          type: array
          items:
            $ref: "#/components/schemas/FileMatch"
      readOnly: true
    FileMatch:
      type: object
      description: File match — identifies a file that matched a fulltext search.
      properties:
        id:
          type: string
          description: ID of the matching file.
          examples:
            - 082ba08f-03c7-409f-b8a6-940a1397ba38
        fileName:
          type: string
          description: File name.
          examples:
            - my-file.pdf
        highlights:
          type: object
          additionalProperties:
            type: array
            items:
              type: string
          description: "Highlighted fragments grouped by matched field (e.g. extractedText,\
            \ title, description, fileName). Matches are wrapped in <em>…</em>. Only\
            \ fields with matches appear."
      readOnly: true
    PagingMetaData:
      type: object
      description: PagingMetaData model
      properties:
        page:
          type: integer
          format: int32
          description: Current page
          examples:
            - "5"
          readOnly: true
        limit:
          type: integer
          format: int32
          description: Displayed objects per page
          examples:
            - "20"
          readOnly: true
        count:
          type: integer
          format: int32
          description: Displayed objects on current page
          examples:
            - "13"
          readOnly: true
        totalRecords:
          type: integer
          format: int64
          description: Total amount of hits based on provided search parameters
          examples:
            - "98"
