        - name: includeConfidential
          in: query
          description: Include confidential records
          required: false
          schema:
            type: boolean
            default: false
          example: true
        - name: includeNonPublic
          in: query
          description: "Admin flag: include DRAFT/REVOKED latest revision."
          required: false
