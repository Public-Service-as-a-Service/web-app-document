    DocumentStatistics:
      type: object
      description: Aggregated usage statistics for a document.
      properties:
        municipalityId:
          type: string
          description: Municipality ID.
          examples:
            - "2281"
        registrationNumber:
          type: string
          description: Registration number.
          examples:
            - 2023-2281-1337
        from:
          type: string
          format: date-time
          description: Inclusive lower bound of the aggregation window. Null if unbounded.
          examples:
            - 2026-01-01T00:00:00+01:00
        to:
          type: string
          format: date-time
          description: Exclusive upper bound of the aggregation window. Null if unbounded.
          examples:
            - 2026-04-17T00:00:00+02:00
        totalAccesses:
          type: integer
          format: int64
          description: Total accesses across all revisions and files within the aggregation
            window.
          examples:
            - "142"
        perRevision:
          type: array
          description: Per-revision breakdown.
          items:
            $ref: "#/components/schemas/RevisionStatistics"
      readOnly: true
    FileStatistics:
      type: object
      description: Per-file usage statistics within a document revision.
      properties:
        documentDataId:
          type: string
          description: Document data ID.
          examples:
            - 082ba08f-03c7-409f-b8a6-940a1397ba38
        fileName:
          type: string
          description: File name. May be null if the file no longer exists in any
            revision of the document.
          examples:
            - report.pdf
        downloads:
          type: integer
          format: int64
          description: "Number of download accesses (Content-Disposition: attachment)."
          examples:
            - "20"
        views:
          type: integer
          format: int64
          description: "Number of view accesses (Content-Disposition: inline)."
          examples:
            - "35"
      readOnly: true
    RevisionStatistics:
      type: object
      description: Per-revision usage statistics for a document.
      properties:
        revision:
          type: integer
          format: int32
          description: Document revision number.
          examples:
            - "2"
        downloads:
          type: integer
          format: int64
          description: Total download accesses across all files in this revision.
          examples:
            - "30"
        views:
          type: integer
          format: int64
          description: Total view accesses across all files in this revision.
          examples:
            - "50"
        perFile:
          type: array
          description: Per-file breakdown.
          items:
            $ref: "#/components/schemas/FileStatistics"
      readOnly: true
    DocumentType:
      type: object
      description: DocumentType model.
      properties:
        type:
          type: string
          description: Identifier for the document type
          examples:
            - EMPLOYMENT_CERTIFICATE
          minLength: 1
        displayName:
          type: string
          description: Display name for the document type
          examples:
            - Anställningsbevis
          minLength: 1
      required:
        - displayName
        - type
