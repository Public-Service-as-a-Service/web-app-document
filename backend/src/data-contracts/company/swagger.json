            application/json:
              schema:
                $ref: '#/components/schemas/ProblemDetails'
            text/json:
              schema:
                $ref: '#/components/schemas/ProblemDetails'
  '/api/v1/company/{municipalityId}/{orgId}/orgtree':
    get:
      tags:
        - Company
      summary: Gets the organization tree for a given organization ID. Any node can be a starting point.
      parameters:
        - name: orgId
          in: path
          description: The organization ID.
          required: true
          schema:
            type: integer
            format: int32
        - name: municipalityId
          in: path
